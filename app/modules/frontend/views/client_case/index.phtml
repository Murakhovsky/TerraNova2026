$priorityLabels = ['low' => 'Низький', 'normal' => 'Звичайний', 'high' => 'Високий', 'urgent' => 'Терміновий'];
$selected = fn($actual, $expected) => (string) $actual === (string) $expected ? 'selected' : '';
$money = function ($amount, $currency): string {
    if ($amount === null || $amount === '') {
        return 'не задано';
    }

    return number_format((float) $amount, 0, '.', ' ') . ' ' . (string) $currency;
};
