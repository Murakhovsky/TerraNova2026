<?php
$h = static fn($value) => htmlspecialchars((string) $value, ENT_QUOTES, 'UTF-8');
$money = static function ($amount, $currency = 'USD') {
    if ($amount === null || $amount === '') {
        return 'за запитом';
    }

    return number_format((float) $amount, 0, '.', ' ') . ' ' . $currency;
};
$submission = $submission ?? null;
$media = $media ?? [];
$pageStatus = $pageStatus ?? null;
$statusMessage = (string) $this->request->getQuery('status', 'string', '');
$statusLabels = [
    'new' => 'Нова',
    'review' => 'В роботі',
    'accepted' => 'Опублікована',
    'rejected' => 'Відхилена',
    'spam' => 'Спам',
];
?>

<header class="tn-header" data-header>
  <a class="tn-logo" href="<?php echo $this->url->get(); ?>" aria-label="Terra Nova CLUB">
    <span class="tn-logo__mark">TN</span>
    <span class="tn-logo__text"><strong>Terra Nova</strong><small>CLUB</small></span>
  </a>
  <button class="tn-menu-button" type="button" aria-expanded="false" aria-controls="site-menu" data-menu-button><span></span><span></span><span></span></button>
  <nav class="tn-nav" id="site-menu" aria-label="Головне меню">
    <a href="<?php echo $this->url->get('property/submissions'); ?>">Модерація</a>
    <a href="<?php echo $this->url->get('property/listing'); ?>">Listing / MLS</a>
    <a href="<?php echo $this->url->get('property/catalog'); ?>">Каталог</a>
  </nav>
</header>

<main class="tn-page">
  <?php if ($pageStatus || !$submission): ?>
    <section class="tn-empty-state tn-empty-state--page">
      <h1>Заявку не знайдено</h1>
      <p><?php echo $h($pageStatus ?: 'Можливо, її видалено або URL некоректний.'); ?></p>
      <a class="tn-btn tn-btn--dark" href="<?php echo $this->url->get('property/submissions'); ?>">До списку заявок</a>
    </section>
  <?php else: ?>
    <section class="tn-page-hero tn-page-hero--catalog">
      <div>
        <p class="tn-kicker"><?php echo $h($submission['submission_ref']); ?></p>
        <h1><?php echo $h($submission['title']); ?></h1>
        <p><?php echo $h($submission['city']); ?><?php if ($submission['address']): ?> / <?php echo $h($submission['address']); ?><?php endif; ?></p>
      </div>
      <div class="tn-page-hero__meta">
        <strong><?php echo $h($statusLabels[$submission['status']] ?? $submission['status']); ?></strong>
        <span><?php echo $h($submission['created_at']); ?></span>
      </div>
    </section>

    <section class="tn-admin-detail">
      <article class="tn-admin-card">
        <?php if ($statusMessage): ?><p class="tn-form-status is-visible"><?php echo $h($statusMessage); ?></p><?php endif; ?>

        <div class="tn-detail-grid">
          <div><span>Тип</span><strong><?php echo $h($submission['property_type']); ?></strong></div>
          <div><span>Операція</span><strong><?php echo $h($submission['deal_type']); ?></strong></div>
          <div><span>Ціна</span><strong><?php echo $h($money($submission['price_amount'], $submission['price_currency'])); ?></strong></div>
          <div><span>Площа</span><strong><?php echo $h($submission['area_total'] ?: '—'); ?></strong></div>
          <div><span>Кімнат</span><strong><?php echo $h($submission['rooms'] ?: '—'); ?></strong></div>
          <div><span>3D</span><strong><?php echo (int) $submission['has_3d_tour'] === 1 ? 'так' : 'ні'; ?></strong></div>
        </div>

        <h2>Опис</h2>
        <p><?php echo nl2br($h($submission['description'])); ?></p>

        <?php if ($submission['features_text']): ?>
          <h2>Особливості</h2>
          <p><?php echo nl2br($h($submission['features_text'])); ?></p>
        <?php endif; ?>

        <?php if ($submission['media_links']): ?>
          <h2>Медіа</h2>
          <p><?php echo nl2br($h($submission['media_links'])); ?></p>
        <?php endif; ?>

        <?php if ($media): ?>
          <h2>Завантажені медіа</h2>
          <div class="tn-media-review-grid">
            <?php foreach ($media as $asset): ?>
              <article>
                <?php if (($asset['kind'] ?? '') === 'image'): ?>
                  <img src="<?php echo $h($asset['public_url']); ?>" alt="<?php echo $h($asset['original_name']); ?>">
                <?php else: ?>
                  <a href="<?php echo $h($asset['public_url']); ?>" target="_blank" rel="noopener"><?php echo $h($asset['original_name']); ?></a>
                <?php endif; ?>
                <span><?php echo $h($asset['role']); ?> / <?php echo $h($asset['mime_type']); ?></span>
              </article>
            <?php endforeach; ?>
          </div>
        <?php endif; ?>

        <?php if ($submission['property_id']): ?>
          <p><a class="tn-btn tn-btn--accent" href="<?php echo $this->url->get('property/show/' . $submission['property_slug']); ?>">Відкрити опублікований об’єкт</a></p>
        <?php endif; ?>
      </article>

      <aside class="tn-admin-card tn-admin-card--side">
        <h2>Контакт</h2>
        <p><strong><?php echo $h($submission['owner_name']); ?></strong></p>
        <p><?php echo $h($submission['owner_phone'] ?: 'Телефон не вказано'); ?></p>
        <p><?php echo $h($submission['owner_email'] ?: 'Email не вказано'); ?></p>
        <p>Зручний канал: <?php echo $h($submission['preferred_contact']); ?></p>

        <form class="tn-moderation-form" action="<?php echo $this->url->get('property/moderate/' . $submission['id']); ?>" method="post">
          <label><span>Нотатка менеджера</span><textarea name="review_note" rows="4" placeholder="Причина відхилення або внутрішній коментар"><?php echo $h($submission['review_note'] ?? ''); ?></textarea></label>
          <button class="tn-btn tn-btn--ghost" type="submit" name="moderation_action" value="review">Взяти в роботу</button>
          <button class="tn-btn tn-btn--accent" type="submit" name="moderation_action" value="publish">Опублікувати</button>
          <button class="tn-btn tn-btn--ghost" type="submit" name="moderation_action" value="reject">Відхилити</button>
          <button class="tn-btn tn-btn--dark" type="submit" name="moderation_action" value="spam">Спам</button>
        </form>
      </aside>
    </section>
  <?php endif; ?>
</main>
