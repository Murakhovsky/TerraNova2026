<?php
$h = static fn($value) => htmlspecialchars((string) $value, ENT_QUOTES, 'UTF-8');
$money = static function ($amount, $currency = 'USD', $period = 'total') {
    if ($amount === null || $amount === '') {
        return 'ціна за запитом';
    }

    $suffix = $period === 'month' ? ' / міс.' : ($period === 'day' ? ' / день' : '');

    return number_format((float) $amount, 0, '.', ' ') . ' ' . $currency . $suffix;
};
$number = static fn($value) => $value === null || $value === '' ? '' : rtrim(rtrim(number_format((float) $value, 1, '.', ' '), '0'), '.');
$absoluteUrl = static function (string $path = '') {
    $scheme = (!empty($_SERVER['HTTPS']) && $_SERVER['HTTPS'] !== 'off') ? 'https' : 'http';
    $host = $_SERVER['HTTP_HOST'] ?? '127.0.0.1:8001';

    return $scheme . '://' . $host . '/' . ltrim($path, '/');
};
$dealLabels = [
    'sale' => 'Продаж',
    'rent' => 'Оренда',
    'investment' => 'Інвестиція',
];
$property = $property ?? null;
$images = $images ?? [];
$features = $features ?? [];
$relatedProperties = $relatedProperties ?? [];
$pageStatus = $pageStatus ?? null;
$inboundRequestStatus = $inboundRequestStatus ?? null;
$propertyMatchStatus = $propertyMatchStatus ?? null;
$managerClientCases = $managerClientCases ?? [];
$returnUrl = ltrim((string) ($_SERVER['REQUEST_URI'] ?? 'property/catalog'), '/');
$fallbackImage = 'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=1400&q=80';

if ($property) {
    $cover = $images[0]['image_url'] ?? $fallbackImage;
    $galleryImages = $images ?: [[
        'image_url' => $fallbackImage,
        'alt_text' => 'Terra Nova CLUB',
        'is_cover' => 1,
    ]];
    $realImageCount = count($images);
    $propertyUrl = $absoluteUrl('property/show/' . $property['slug']);
    $phoneRaw = (string) ($property['agent_phone'] ?? '');
    $phoneHref = $phoneRaw !== '' ? preg_replace('/[^0-9+]/', '', $phoneRaw) : '';
    $telegramRaw = trim((string) ($property['agent_telegram'] ?? ''));
    $telegramHref = $telegramRaw === ''
        ? ''
        : (str_starts_with($telegramRaw, 'http') ? $telegramRaw : 'https://t.me/' . ltrim($telegramRaw, '@'));
    $viberHref = $phoneHref !== '' ? 'viber://chat?number=' . rawurlencode($phoneHref) : '';
    $breadcrumbJson = [
        '@context' => 'https://schema.org',
        '@type' => 'BreadcrumbList',
        'itemListElement' => [
            ['@type' => 'ListItem', 'position' => 1, 'name' => 'Головна', 'item' => $absoluteUrl()],
            ['@type' => 'ListItem', 'position' => 2, 'name' => 'Каталог', 'item' => $absoluteUrl('property/catalog')],
            ['@type' => 'ListItem', 'position' => 3, 'name' => $property['title'], 'item' => $propertyUrl],
        ],
    ];
    $propertyJson = [
        '@context' => 'https://schema.org',
        '@type' => 'Product',
        'name' => $property['title'],
        'description' => $property['meta_description'] ?: ($property['short_description'] ?: $property['description']),
        'image' => array_values(array_map(static fn($image) => $image['image_url'], $images)) ?: [$cover],
        'sku' => $property['public_id'],
        'url' => $propertyUrl,
        'category' => $property['type_name'],
        'offers' => [
            '@type' => 'Offer',
            'availability' => 'https://schema.org/InStock',
            'price' => $property['price_amount'] ?: 0,
            'priceCurrency' => $property['price_currency'] ?: 'USD',
            'url' => $propertyUrl,
        ],
        'additionalProperty' => array_values(array_filter([
            $property['area_total'] ? ['@type' => 'PropertyValue', 'name' => 'Площа', 'value' => $number($property['area_total']) . ' м²'] : null,
            $property['rooms'] ? ['@type' => 'PropertyValue', 'name' => 'Кімнати', 'value' => $number($property['rooms'])] : null,
            $property['bedrooms'] ? ['@type' => 'PropertyValue', 'name' => 'Спальні', 'value' => (string) $property['bedrooms']] : null,
            $property['bathrooms'] ? ['@type' => 'PropertyValue', 'name' => 'Санвузли', 'value' => (string) $property['bathrooms']] : null,
        ])),
    ];

    if (!empty($property['city'])) {
        $propertyJson['areaServed'] = $property['city'];
    }
    if (!empty($property['agent_name'])) {
        $propertyJson['seller'] = [
            '@type' => 'RealEstateAgent',
            'name' => $property['agent_name'],
            'telephone' => $property['agent_phone'] ?? null,
            'email' => $property['agent_email'] ?? null,
        ];
    }
}
?>

