<?php
$h = static fn($value) => htmlspecialchars((string) $value, ENT_QUOTES, 'UTF-8');
$statusLabels = [
    'new' => 'Нові',
    'review' => 'В роботі',
    'accepted' => 'Опубліковані',
    'rejected' => 'Відхилені',
    'spam' => 'Спам',
];
$submissions = $submissions ?? [];
$counts = $counts ?? [];
$status = $status ?? '';
$pageStatus = $pageStatus ?? null;
?>

<header class="tn-header" data-header>
  <a class="tn-logo" href="<?php echo $this->url->get(); ?>" aria-label="Terra Nova CLUB">
    <span class="tn-logo__mark">TN</span>
    <span class="tn-logo__text"><strong>Terra Nova</strong><small>CLUB</small></span>
  </a>
  <button class="tn-menu-button" type="button" aria-expanded="false" aria-controls="site-menu" data-menu-button><span></span><span></span><span></span></button>
  <nav class="tn-nav" id="site-menu" aria-label="Головне меню">
    <a href="<?php echo $this->url->get('property/submissions'); ?>">Модерація</a>
    <a href="<?php echo $this->url->get('property/listing'); ?>">Listing / MLS</a>
    <a href="<?php echo $this->url->get('property/catalog'); ?>">Каталог</a>
    <a href="<?php echo $this->url->get('property/submit'); ?>">Подати об’єкт</a>
  </nav>
</header>

<main class="tn-page">
  <section class="tn-page-hero tn-page-hero--catalog">
    <div>
      <p class="tn-kicker">CRM Release 0</p>
      <h1>Модерація поданих об’єктів</h1>
      <p>Перший менеджерський режим: перегляд заявок, зміна статусів і публікація об’єкта в каталог.</p>
    </div>
    <div class="tn-page-hero__meta">
      <strong><?php echo (int) ($counts['new'] ?? 0); ?></strong>
      <span>нові заявки</span>
    </div>
  </section>

  <section class="tn-admin-workspace">
    <nav class="tn-view-switch" aria-label="Фільтр заявок">
      <a class="<?php echo $status === '' ? 'is-active' : ''; ?>" href="<?php echo $this->url->get('property/submissions'); ?>">Усі</a>
      <?php foreach ($statusLabels as $code => $label): ?>
        <a class="<?php echo $status === $code ? 'is-active' : ''; ?>" href="<?php echo $this->url->get('property/submissions?status=' . $code); ?>"><?php echo $h($label); ?> · <?php echo (int) ($counts[$code] ?? 0); ?></a>
      <?php endforeach; ?>
    </nav>

    <?php if ($pageStatus): ?>
      <div class="tn-empty-state"><h2>Заявки недоступні</h2><p><?php echo $h($pageStatus); ?></p></div>
    <?php elseif (!$submissions): ?>
      <div class="tn-empty-state"><h2>Заявок у цьому статусі немає</h2><p>Нові подані об’єкти з’являться тут після відправки форми.</p></div>
    <?php else: ?>
      <div class="tn-listing-table-wrap">
        <table class="tn-listing-table">
          <thead>
            <tr>
              <th>Ref</th>
              <th>Об’єкт</th>
              <th>Контакт</th>
              <th>Операція</th>
              <th>Місто</th>
              <th>Статус</th>
              <th>Дата</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <?php foreach ($submissions as $submission): ?>
              <tr>
                <td><strong><?php echo $h($submission['submission_ref']); ?></strong></td>
                <td>
                  <a class="tn-listing-title" href="<?php echo $this->url->get('property/submission/' . $submission['id']); ?>"><?php echo $h($submission['title']); ?></a>
                  <span><?php echo $h($submission['property_type']); ?></span>
                </td>
                <td>
                  <?php echo $h($submission['owner_name']); ?>
                  <span><?php echo $h($submission['owner_phone'] ?: $submission['owner_email']); ?></span>
                </td>
                <td><?php echo $h($submission['deal_type']); ?></td>
                <td><?php echo $h($submission['city']); ?></td>
                <td><span class="tn-status-pill"><?php echo $h($statusLabels[$submission['status']] ?? $submission['status']); ?></span></td>
                <td><?php echo $h($submission['created_at']); ?></td>
                <td><a class="tn-row-link" href="<?php echo $this->url->get('property/submission/' . $submission['id']); ?>">Відкрити</a></td>
              </tr>
            <?php endforeach; ?>
          </tbody>
        </table>
      </div>
    <?php endif; ?>
