    'area_desc' => 'Більша площа',
];
$statusLabels = [
    'published' => 'Опубліковано',
    'moderation' => 'Модерація',
    'reserved' => 'Резерв',
    'sold' => 'Продано',
];
$sourceLabels = [
    'own' => 'Terra Nova',
    'partner' => 'Партнер',
    'realtor' => 'Рієлтор',
    'owner' => 'Власник',
    'developer' => 'Девелопер',
];
