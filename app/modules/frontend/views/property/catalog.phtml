$properties = $properties ?? [];
$types = $types ?? [];
$locations = $locations ?? [];
$catalogStatus = $catalogStatus ?? null;
$inboundRequestStatus = $inboundRequestStatus ?? null;
$propertyMatchStatus = $propertyMatchStatus ?? null;
$managerClientCases = $managerClientCases ?? [];
