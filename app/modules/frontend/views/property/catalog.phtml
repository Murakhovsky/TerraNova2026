$resultCount = $resultCount ?? count($properties);
$catalogStats = $catalogStats ?? [];
$fallbackImage = 'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=900&q=80';
$activeFilters = [];

if (($filters['q'] ?? '') !== '') {
    $activeFilters[] = 'Пошук: ' . $filters['q'];
}
if (($filters['deal_type'] ?? '') !== '') {
    $activeFilters[] = $dealLabels[$filters['deal_type']] ?? $filters['deal_type'];
}
foreach ($types as $type) {
    if (($filters['type'] ?? '') === $type['code']) {
        $activeFilters[] = $type['name_uk'];
    }
}
foreach ($locations as $location) {
    if (($filters['location'] ?? '') === $location['slug']) {
        $activeFilters[] = $location['city'];
    }
}
if (($filters['price_min'] ?? null) !== null || ($filters['price_max'] ?? null) !== null) {
    $activeFilters[] = 'Бюджет';
}
if (($filters['area_min'] ?? null) !== null) {
    $activeFilters[] = 'Від ' . $number($filters['area_min']) . ' м²';
}
if (($filters['rooms_min'] ?? null) !== null) {
    $activeFilters[] = 'Від ' . $number($filters['rooms_min']) . ' кімн.';
}

$itemList = [
    '@context' => 'https://schema.org',
    '@type' => 'ItemList',
    'name' => 'Каталог нерухомості Terra Nova CLUB',
    'numberOfItems' => count($properties),
    'itemListElement' => [],
];
foreach ($properties as $index => $property) {
