<?php
$h = static fn($value) => htmlspecialchars((string) $value, ENT_QUOTES, 'UTF-8');
$money = static function ($amount, $currency = 'USD', $period = 'total') {
    if ($amount === null || $amount === '') {
        return 'за запитом';
    }

    $suffix = $period === 'month' ? ' / міс.' : ($period === 'day' ? ' / день' : '');

    return number_format((float) $amount, 0, '.', ' ') . ' ' . $currency . $suffix;
};
$dealLabels = ['sale' => 'Продаж', 'rent' => 'Оренда', 'investment' => 'Інвестиція'];
$statusLabels = [
    'draft' => 'Чернетка',
    'moderation' => 'Модерація',
    'published' => 'Опубліковано',
    'reserved' => 'Резерв',
    'sold' => 'Продано',
    'archived' => 'Архів',
];
$sourceLabels = [
    'own' => 'Власний',
    'partner' => 'Партнер',
    'realtor' => 'Рієлтор',
    'owner' => 'Власник',
    'developer' => 'Девелопер',
];
$sortLabels = ['updated' => 'Оновлені', 'newest' => 'Нові', 'price_desc' => 'Ціна спадання', 'price_asc' => 'Ціна зростання'];
$filters = $filters ?? [];
$properties = $properties ?? [];
$types = $types ?? [];
$locations = $locations ?? [];
$stats = $stats ?? [];
$pageStatus = $pageStatus ?? null;
$actionStatus = $actionStatus ?? null;
$selected = static fn($current, $expected) => (string) $current === (string) $expected ? 'selected' : '';
$returnParams = [];
foreach (['q', 'status', 'deal_type', 'type_id', 'location_id', 'source_type', 'sort'] as $filterKey) {
    if (($filters[$filterKey] ?? '') !== '' && ($filters[$filterKey] ?? 0) !== 0) {
        $returnParams[$filterKey] = $filters[$filterKey];
    }
}
$returnUrl = 'property/manage' . ($returnParams ? '?' . http_build_query($returnParams) : '');
?>

